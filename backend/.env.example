# Copy this file to .env and fill in your own values before running the server.

# SQLite is used for local development so there's nothing extra to install.
# Swap this for a postgresql:// URL when you deploy.
DATABASE_URL="file:./dev.db"

# Generate a real secret with: openssl rand -base64 48
JWT_SECRET="replace_this_with_a_long_random_string"
JWT_EXPIRES_IN="7d"

PORT=4000
CORS_ORIGIN="http://localhost:5173"
BCRYPT_SALT_ROUNDS=12
